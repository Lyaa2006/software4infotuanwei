<view class="container">
  <view class="card" wx:if="{{!isAdmin}}">
    <view class="section_title">选择模板</view>
    <picker mode="selector" range="{{templateTitles}}" value="{{templateIndex}}" bindchange="onTemplatePickerChange">
      <view class="input">{{selectedTemplateTitle || '请选择模板'}}</view>
    </picker>
    <view class="hint" wx:if="{{selectedTemplateMeta}}">{{selectedTemplateMeta}}</view>
    <view class="btn_row">
      <button class="ghost" size="mini" disabled="{{!selectedTemplateId}}" bindtap="onDownloadSelectedTemplate">下载模板</button>
      <button class="ghost" size="mini" disabled="{{!selectedTemplateId}}" bindtap="onPreviewPdf">预览</button>
      <button class="primary" size="mini" type="primary" disabled="{{!selectedTemplateId}}" bindtap="onDownloadPdf">下载PDF</button>
    </view>
  </view>

  <view class="card" wx:if="{{!isAdmin}}">
    <view class="section_title">填写字段</view>
    <view class="hint">系统会自动填充：{{nameHint}}</view>
    <view class="hint" wx:if="{{!selectedTemplateId}}">请先选择模板</view>

    <view wx:if="{{selectedTemplateId}}">
      <view class="empty" wx:if="{{!manualFields.length}}">该模板无需手动填写字段</view>
      <view class="form_row" wx:for="{{manualFields}}" wx:key="key">
        <view class="label">{{item.label}}</view>
        <textarea
          wx:if="{{item.multiline}}"
          class="textarea"
          placeholder="{{item.placeholder}}"
          value="{{item.value}}"
          data-key="{{item.key}}"
          bindinput="onManualFieldInput"
          auto-height
          maxlength="500"
        ></textarea>
        <input
          wx:else
          class="input"
          placeholder="{{item.placeholder}}"
          value="{{item.value}}"
          data-key="{{item.key}}"
          bindinput="onManualFieldInput"
        />
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{isAdmin}}">
    <view class="section_title">模板列表</view>
    <view class="list" wx:if="{{templates.length}}">
      <view class="item" wx:for="{{templates}}" wx:key="_id">
        <view class="item_top">
          <view class="item_title">{{item.title}}</view>
          <view class="item_meta">{{item.format.toUpperCase()}}{{item.category ? (' · ' + item.category) : ''}}</view>
        </view>
        <view class="item_actions">
          <button size="mini" class="ghost" data-id="{{item._id}}" bindtap="onDownloadTemplate">下载模板</button>
        </view>
      </view>
    </view>
    <view class="empty" wx:if="{{!templates.length}}">暂无模板</view>
  </view>

  <view class="card" wx:if="{{isAdmin}}">
    <view class="section_title">管理员：上传新模板</view>
    <view class="form_row">
      <view class="label">标题</view>
      <input class="input" placeholder="例如：请假条模板（通用）" value="{{uploadTitle}}" bindinput="onUploadTitleInput" maxlength="60" />
    </view>
    <view class="form_row">
      <view class="label">分类</view>
      <input class="input" placeholder="例如：请假条/证明/预算表" value="{{uploadCategory}}" bindinput="onUploadCategoryInput" maxlength="30" />
    </view>
    <view class="form_row">
      <view class="label">文件</view>
      <view class="hint">{{uploadFileName || '未选择文件（支持 .html / .txt / .xlsx）'}}</view>
      <view class="btn_row">
        <button class="ghost" disabled="{{uploading}}" bindtap="onChooseFile">选择文件</button>
        <button class="primary" type="primary" loading="{{uploading}}" disabled="{{uploading}}" bindtap="onUpload">上传</button>
      </view>
    </view>
    <view class="hint">提示：如需学生端动态字段，请在模板中使用「双大括号字段名双大括号」占位符</view>
  </view>
</view>
