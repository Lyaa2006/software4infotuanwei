page {
  padding: 32rpx 5vw;
  background-color: #f6f6f6;
}

.container {
  font-family: PingFang SC;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section_title {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.9);
  margin-bottom: 16rpx;
}

.form_row {
  margin-bottom: 18rpx;
}

.label {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.65);
  margin-bottom: 12rpx;
}

.input {
  height: 88rpx;
  background: #f6f6f6;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  width: 100%;
}

.picker_row {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.picker_cell {
  flex: 1;
}

.picker {
  min-height: 88rpx;
  background: #f6f6f6;
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  width: 100%;
  color: rgba(0, 0, 0, 0.9);
}

.textarea {
  background: #f6f6f6;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  width: 100%;
}

.btn_row {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
  margin-top: 12rpx;
}

.primary {
  margin: 0;
}

.ghost {
  margin: 0;
  background: rgba(0, 0, 0, 0.06);
}

.date_clear_btn {
  flex: none;
  white-space: nowrap;
}

.danger {
  color: #b42318;
  background: #fee4e2;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.item {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 18rpx;
}

.item_top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.item_title {
  font-size: 30rpx;
  color: rgba(0, 0, 0, 0.9);
  flex: 1;
}

.item_meta {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.55);
  white-space: nowrap;
}

.item_actions {
  display: flex;
  gap: 12rpx;
  justify-content: flex-end;
  margin-top: 12rpx;
}

.empty {
  text-align: center;
  color: rgba(0, 0, 0, 0.45);
  font-size: 28rpx;
  padding: 20rpx 0 8rpx;
}

.hint {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.5);
}
