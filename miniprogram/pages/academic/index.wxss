page {
  padding: 32rpx 5vw;
  background-color: #f6f6f6;
}

.container {
  font-family: PingFang SC;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.admin_card {
  gap: 20rpx;
}

.section_title {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.9);
  margin-bottom: 16rpx;
}

.hint {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.5);
  margin-top: 10rpx;
  line-height: 36rpx;
}

.no_top_margin {
  margin-top: 0;
}

.form_row {
  margin-bottom: 18rpx;
}

.label {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.65);
  margin-bottom: 12rpx;
}

.input {
  height: 88rpx;
  background: #f6f6f6;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  width: 100%;
}

.btn_row {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
  margin-top: 12rpx;
}

.btn_stack {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 16rpx;
}

.primary {
  margin: 0;
}

.ghost {
  margin: 0;
  background: rgba(0, 0, 0, 0.06);
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.item {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 18rpx;
}

.item_title {
  font-size: 30rpx;
  color: rgba(0, 0, 0, 0.9);
  margin-bottom: 8rpx;
}

.item_meta {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.55);
  margin-bottom: 10rpx;
}

.badge_ok {
  font-size: 22rpx;
  color: #1a7f37;
  background: rgba(26, 127, 55, 0.12);
  padding: 6rpx 10rpx;
  border-radius: 10rpx;
  display: inline-block;
}

.badge_bad {
  font-size: 22rpx;
  color: #b42318;
  background: rgba(180, 35, 24, 0.12);
  padding: 6rpx 10rpx;
  border-radius: 10rpx;
  display: inline-block;
}

.admin_header {
  margin-bottom: 18rpx;
}

.panel_title {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.88);
  margin: 20rpx 0 14rpx;
}

.editor_title {
  margin-top: 28rpx;
}

.plan_item {
  border: 2rpx solid transparent;
}

.plan_item_active {
  border-color: #1677ff;
  background: #f3f8ff;
}

.plan_item_actions {
  justify-content: flex-start;
}

.module_list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.module_card {
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 20rpx;
}

.module_header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.module_index {
  font-size: 22rpx;
  color: #1677ff;
  margin-bottom: 6rpx;
}

.module_title {
  font-size: 30rpx;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.88);
}

.course_list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.course_row {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 16rpx;
}

.course_number {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.45);
  margin-bottom: 10rpx;
}

.course_fields {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.compact_input {
  height: 76rpx;
  font-size: 28rpx;
}

.course_delete {
  margin-top: 12rpx;
}

.left_actions {
  justify-content: flex-start;
}

.wrap_actions {
  flex-wrap: wrap;
  justify-content: flex-start;
}
