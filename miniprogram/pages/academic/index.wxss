page {
  padding: 32rpx 5vw;
  background-color: #f6f6f6;
}

.container {
  font-family: PingFang SC;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section_title {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.9);
  margin-bottom: 16rpx;
}

.hint {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.5);
  margin-top: 10rpx;
  line-height: 36rpx;
}

.form_row {
  margin-bottom: 18rpx;
}

.label {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.65);
  margin-bottom: 12rpx;
}

.input {
  height: 88rpx;
  background: #f6f6f6;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  width: 100%;
}

.textarea {
  background: #f6f6f6;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  width: 100%;
  line-height: 40rpx;
}

.btn_row {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
  margin-top: 12rpx;
}

.primary {
  margin: 0;
}

.ghost {
  margin: 0;
  background: rgba(0, 0, 0, 0.06);
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.item {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 18rpx;
}

.item_title {
  font-size: 30rpx;
  color: rgba(0, 0, 0, 0.9);
  margin-bottom: 8rpx;
}

.item_meta {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.55);
  margin-bottom: 10rpx;
}

.badge_ok {
  font-size: 22rpx;
  color: #1a7f37;
  background: rgba(26, 127, 55, 0.12);
  padding: 6rpx 10rpx;
  border-radius: 10rpx;
  display: inline-block;
}

.badge_bad {
  font-size: 22rpx;
  color: #b42318;
  background: rgba(180, 35, 24, 0.12);
  padding: 6rpx 10rpx;
  border-radius: 10rpx;
  display: inline-block;
}
