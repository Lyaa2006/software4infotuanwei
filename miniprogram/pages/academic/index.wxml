<view class="container">
  <view class="card">
    <view class="section_title">学业预警</view>
    <view class="form_row">
      <view class="label">学期（用于推荐本学期开课）</view>
      <input class="input" placeholder="示例：2026-春 / 2026-秋" value="{{semester}}" bindinput="onSemesterInput" maxlength="16" />
    </view>
    <view class="form_row" wx:if="{{isStudent}}">
      <view class="label">培养方案</view>
      <picker mode="selector" range="{{planNames}}" value="{{planIndex}}" bindchange="onPlanPickerChange">
        <view class="input">{{selectedPlanName || '请选择培养方案'}}</view>
      </picker>
    </view>
    <view class="btn_row" wx:if="{{isStudent}}">
      <button class="ghost" disabled="{{loading}}" bindtap="onReload">刷新</button>
      <button class="primary" type="primary" loading="{{uploading}}" disabled="{{uploading}}" bindtap="onChooseTranscript">上传成绩单</button>
    </view>
    <view class="hint" wx:if="{{isStudent}}">可手动选择培养方案进行比对；未选择时会尝试从学生标签自动识别</view>
    <view class="hint" wx:if="{{isStudent}}">支持 HTML / CSV / TXT。PDF 解析需后端额外依赖，若提示不支持请改传 HTML/CSV</view>
  </view>

  <view class="card" wx:if="{{isStudent && reportLoaded}}">
    <view class="section_title">对比结果</view>
    <view class="hint">培养方案：{{report.planName || '-'}}</view>
    <view class="hint" wx:if="{{report.transcriptCreatedAtText}}">最近上传：{{report.transcriptCreatedAtText}}</view>
    <view class="hint" wx:if="{{!report.hasTranscript}}">尚未上传成绩单</view>

    <view class="list" wx:if="{{report.hasTranscript}}">
      <view class="item" wx:for="{{report.modules}}" wx:key="name">
        <view class="item_title">{{item.name || '模块'}}</view>
        <view class="item_meta">
          需 {{item.requiredCredits}} 学分 · 已修 {{item.earnedCredits}} 学分 · 缺 {{item.deficitCredits}} 学分
        </view>
        <view class="{{item.deficitCredits > 0 ? 'badge_bad' : 'badge_ok'}}">{{item.deficitCredits > 0 ? '未修满' : '已满足'}}</view>
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{isStudent && report.hasTranscript}}">
    <view class="section_title">推荐课程</view>
    <view class="list" wx:if="{{report.recommendations.length}}">
      <view class="item" wx:for="{{report.recommendations}}" wx:key="courseName">
        <view class="item_title">{{item.courseName || item.courseCode}}</view>
        <view class="item_meta">{{item.semester}} · {{item.credits}} 学分 · {{item.moduleName || '-'}}</view>
        <view class="hint">{{item.reason}}</view>
      </view>
    </view>
    <view class="hint" wx:if="{{!report.recommendations.length}}">暂无推荐（可能未配置本学期开课课程，或必修已修完）</view>
  </view>

  <view class="card" wx:if="{{isStudent && report.hasTranscript}}">
    <view class="section_title">未修课程</view>
    <view class="list" wx:if="{{report.missingCourses.length}}">
      <view class="item" wx:for="{{report.missingCourses}}" wx:key="name">
        <view class="item_title">{{item.name || item.code}}</view>
        <view class="item_meta">{{item.code || '-' }} · {{item.credits}} 学分 · {{item.moduleName || '-'}}</view>
        <view class="badge_bad">未修</view>
      </view>
    </view>
    <view class="hint" wx:if="{{!report.missingCourses.length}}">暂无未修课程</view>
  </view>

  <view class="card" wx:if="{{isAdmin}}">
    <view class="section_title">管理员：培养方案</view>
    <view class="form_row">
      <view class="label">方案名称</view>
      <input class="input" placeholder="例如：计算机2023" value="{{planFormName}}" bindinput="onPlanNameInput" maxlength="60" />
    </view>
    <view class="form_row">
      <view class="label">modules JSON（数组）</view>
      <textarea class="textarea" placeholder="示例见下方提示" value="{{planFormModulesJson}}" bindinput="onPlanModulesInput" auto-height></textarea>
      <view class="hint">格式示例：[{"name":"公共必修","requiredCredits":20,"courses":[{"code":"A001","name":"高等数学","credits":4}]}]</view>
    </view>
    <view class="btn_row">
      <button class="ghost" disabled="{{loading}}" bindtap="onResetPlanForm">清空</button>
      <button class="ghost" loading="{{importingPlan}}" disabled="{{importingPlan}}" bindtap="onImportPlanFile">导入</button>
      <button class="primary" type="primary" loading="{{savingPlan}}" disabled="{{savingPlan}}" bindtap="onSavePlan">{{planEditingId ? '更新' : '新增'}}</button>
    </view>

    <view class="list" wx:if="{{plans.length}}">
      <view class="item" wx:for="{{plans}}" wx:key="_id">
        <view class="item_title">{{item.name}}</view>
        <view class="item_meta">更新时间：{{item.updatedAtText}}</view>
        <view class="btn_row">
          <button size="mini" class="ghost" data-id="{{item._id}}" bindtap="onEditPlan">编辑</button>
          <button size="mini" class="ghost" data-id="{{item._id}}" bindtap="onDeletePlan">删除</button>
        </view>
      </view>
    </view>
    <view class="hint" wx:if="{{!plans.length}}">暂无培养方案</view>
  </view>

  <view class="card" wx:if="{{isAdmin}}">
    <view class="section_title">管理员：本学期开课</view>
    <view class="form_row">
      <view class="label">学期</view>
      <input class="input" placeholder="例如：2026-春" value="{{adminSemester}}" bindinput="onAdminSemesterInput" maxlength="16" />
    </view>
    <view class="form_row">
      <view class="label">课程列表（CSV，每行：课程代码,课程名,学分,模块名）</view>
      <textarea class="textarea" placeholder="A001,高等数学,4,公共必修" value="{{semesterCoursesCsv}}" bindinput="onSemesterCoursesInput" auto-height></textarea>
    </view>
    <view class="btn_row">
      <button class="ghost" disabled="{{loading}}" bindtap="onLoadSemesterCourses">加载已配置</button>
      <button class="primary" type="primary" loading="{{savingSemesterCourses}}" disabled="{{savingSemesterCourses}}" bindtap="onSaveSemesterCourses">保存</button>
    </view>
    <view class="hint" wx:if="{{semesterCoursesLoadedCount}}">已加载 {{semesterCoursesLoadedCount}} 条课程</view>
  </view>
</view>
