<view class="container">
  <view class="header">
    <view class="title">功能首页</view>
    <button class="logout" size="mini" bindtap="onLogout">退出登录</button>
  </view>

  <view class="user_card" wx:if="{{user}}">
    <view class="user_line">身份：{{user.role === 'admin' ? '管理员' : '学生'}}</view>
    <view class="user_line">学工号：{{user.accountId}}</view>
  </view>

  <view class="env_card" wx:if="{{runtimeEnv}}">
    <view class="env_header">
      <view class="env_title">当前测试环境</view>
      <picker mode="selector" range="{{envOptions}}" range-key="label" value="{{envIndex}}" bindchange="onEnvChange">
        <view class="env_switch">切换</view>
      </picker>
    </view>
    <view class="env_name">{{runtimeEnv.envName}}</view>
    <view class="env_url">{{runtimeEnv.baseUrl}}</view>
    <view class="env_note">{{runtimeEnv.note}}</view>
    <view class="env_warn" wx:if="{{!runtimeEnv.supportsRealDevice}}">
      当前地址主要用于开发者工具联调；真机调试请切换到 HTTPS 的临时公网测试环境。
    </view>
  </view>

  <view class="list">
    <view
      class="item"
      wx:for="{{features}}"
      wx:key="key"
      data-key="{{item.key}}"
      data-title="{{item.title}}"
      bindtap="onTapFeature"
    >
      <view class="item_title">{{item.title}}</view>
      <view class="item_tip">接口已预留</view>
    </view>
  </view>
</view>

