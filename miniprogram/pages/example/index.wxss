page {
  padding: 32rpx 5vw;
  background-color: #f6f6f6;
}

.container {
  font-family: PingFang SC;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #000;
}

.logout {
  margin: 0;
}

.user_card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.user_line {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.75);
  line-height: 44rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  align-items: center;
  width: 100%;
}

.item {
  background: #ffffff;
  border-radius: 16rpx;
  width: 75vw;
  max-width: 100%;
  min-height: 108rpx;
  padding: 26rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.item_title {
  font-size: 34rpx;
  line-height: 46rpx;
  color: rgba(0, 0, 0, 0.9);
}

