page {
  padding: 32rpx;
  background-color: #f6f6f6;
}

.container {
  font-family: PingFang SC;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #000;
}

.logout {
  margin: 0;
}

.user_card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.user_line {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.75);
  line-height: 44rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.item_title {
  font-size: 32rpx;
  color: rgba(0, 0, 0, 0.9);
  margin-bottom: 8rpx;
}

.item_tip {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.5);
}

