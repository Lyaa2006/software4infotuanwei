page {
  padding: 32rpx;
  background-color: #f6f6f6;
}

.container {
  font-family: PingFang SC;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.top_head {
  font-size: 30rpx;
  color: rgba(0, 0, 0, 0.85);
  line-height: 46rpx;
  margin-bottom: 12rpx;
}

.top_extra {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.75);
  line-height: 44rpx;
}

.section_title {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.9);
  margin-bottom: 16rpx;
}

.progress {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.progress_item {
  display: flex;
  align-items: stretch;
  gap: 20rpx;
}

.timeline {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.node_wrap {
  flex: 1;
  min-height: 56rpx;
  display: flex;
  align-items: center;
}

.node_circle {
  width: 28rpx;
  height: 28rpx;
  border-radius: 14rpx;
  background: #d9d9d9;
  margin-bottom: 12rpx;
}

.node_circle.done {
  background: #22c55e;
}

.node_circle.current {
  background: #2563eb;
}

.node_circle.todo {
  background: #d9d9d9;
}

.node_label {
  font-size: 28rpx;
  text-align: left;
  color: rgba(0, 0, 0, 0.55);
  line-height: 40rpx;
}

.node_label.done {
  color: rgba(0, 0, 0, 0.75);
}

.node_label.current {
  color: rgba(37, 99, 235, 0.95);
  font-weight: 600;
}

.node_line {
  width: 6rpx;
  min-height: 56rpx;
  border-radius: 4rpx;
  background: #d9d9d9;
  margin-top: 8rpx;
}

.node_line.done {
  background: rgba(34, 197, 94, 0.7);
}

.node_line.current {
  background: rgba(37, 99, 235, 0.55);
}

.node_line.todo {
  background: #d9d9d9;
}

.hint_card {
  padding-top: 18rpx;
  padding-bottom: 18rpx;
}

.hint {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.55);
  line-height: 40rpx;
}

.hint2 {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.7);
  line-height: 40rpx;
}

.detail_mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.38);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
  z-index: 999;
}

.detail_dialog {
  width: 100%;
  max-width: 620rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx 28rpx 24rpx;
  box-sizing: border-box;
}

.detail_title {
  font-size: 30rpx;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.9);
  line-height: 44rpx;
  margin-bottom: 18rpx;
}

.detail_line {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.78);
  line-height: 40rpx;
}

.detail_line + .detail_line {
  margin-top: 8rpx;
}

.detail_actions {
  margin-top: 26rpx;
  display: flex;
  justify-content: flex-end;
}

.detail_btn {
  min-width: 180rpx;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 26rpx;
  line-height: 1;
  text-align: center;
}

