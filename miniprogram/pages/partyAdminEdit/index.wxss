page {
  padding: 32rpx;
  background-color: #f6f6f6;
}

.container {
  font-family: PingFang SC;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.title {
  font-size: 30rpx;
  color: rgba(0, 0, 0, 0.9);
  font-weight: 600;
  margin-bottom: 18rpx;
}

.section_title {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.9);
  margin-bottom: 16rpx;
}

.form_row {
  margin-bottom: 18rpx;
}

.label {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.65);
  margin-bottom: 10rpx;
}

.input {
  height: 88rpx;
  background: #f6f6f6;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  width: 100%;
}

.row {
  display: flex;
  gap: 14rpx;
  align-items: center;
}

.picker {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  background: #f6f6f6;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  color: rgba(0, 0, 0, 0.85);
}

.ghost {
  margin: 0;
  background: rgba(0, 0, 0, 0.06);
}

.btn_row {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
  margin-top: 8rpx;
}

.primary {
  margin: 0;
}

