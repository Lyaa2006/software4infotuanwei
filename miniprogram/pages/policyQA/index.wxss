page {
  padding: 32rpx;
  background-color: #f6f6f6;
}

.container {
  font-family: PingFang SC;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section_title {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.9);
  margin-bottom: 16rpx;
}

.textarea {
  background: #f6f6f6;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 30rpx;
  margin-bottom: 16rpx;
  box-sizing: border-box;
  width: 100%;
}

.input {
  height: 88rpx;
  background: #f6f6f6;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  width: 100%;
}

.answer {
  font-size: 30rpx;
  color: rgba(0, 0, 0, 0.85);
  line-height: 44rpx;
  padding: 16rpx 0;
}

.meta {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.5);
}

.form_row {
  margin-bottom: 18rpx;
}

.label {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.65);
  margin-bottom: 12rpx;
}

.btn_row {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
  margin-top: 12rpx;
  margin-bottom: 20rpx;
}

.primary {
  margin: 0;
}

.ghost {
  margin: 0;
  background: rgba(0, 0, 0, 0.06);
}

.danger {
  margin: 0;
  background: rgba(229, 69, 69, 0.1);
  color: #e54545;
}

.list_title {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.75);
  margin: 12rpx 0 10rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.item {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 18rpx;
}

.item_q {
  font-size: 30rpx;
  color: rgba(0, 0, 0, 0.9);
  margin-bottom: 8rpx;
}

.item_k {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.6);
  margin-bottom: 8rpx;
}

.item_a {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.75);
  line-height: 42rpx;
  margin-bottom: 12rpx;
}

.item_actions {
  display: flex;
  gap: 12rpx;
  justify-content: flex-end;
}

.empty {
  text-align: center;
  color: rgba(0, 0, 0, 0.45);
  font-size: 28rpx;
  padding: 20rpx 0 8rpx;
}

