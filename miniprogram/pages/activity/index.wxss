page {
  padding: 32rpx;
  background-color: #f6f6f6;
}

.container {
  font-family: PingFang SC;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section_title {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.9);
  margin-bottom: 16rpx;
}

.hint {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.5);
  margin-top: 8rpx;
}

.form_row {
  margin-bottom: 18rpx;
}

.label {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.65);
  margin-bottom: 12rpx;
}

.input {
  height: 88rpx;
  background: #f6f6f6;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  width: 100%;
}

.textarea {
  background: #f6f6f6;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  width: 100%;
}

.btn_row {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
  margin-top: 12rpx;
}

.primary {
  margin: 0;
}

.ghost {
  margin: 0;
  background: rgba(0, 0, 0, 0.06);
}

.danger {
  margin: 0;
  background: rgba(229, 69, 69, 0.1);
  color: #e54545;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.item {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 18rpx;
}

.item_title {
  font-size: 30rpx;
  color: rgba(0, 0, 0, 0.9);
  margin-bottom: 8rpx;
}

.item_meta {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.55);
  margin-bottom: 10rpx;
}

.item_desc {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.75);
  line-height: 42rpx;
}

.badge {
  font-size: 22rpx;
  color: rgba(0, 0, 0, 0.6);
  background: rgba(0, 0, 0, 0.08);
  padding: 6rpx 10rpx;
  border-radius: 10rpx;
  display: inline-block;
  margin-top: 10rpx;
}

.img_row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.img {
  width: 210rpx;
  height: 210rpx;
  border-radius: 12rpx;
}

.student_item {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 18rpx;
  display: flex;
  gap: 16rpx;
  align-items: center;
  justify-content: space-between;
}

.student_left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
}

.student_id {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.85);
}

.student_tags {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.55);
}
