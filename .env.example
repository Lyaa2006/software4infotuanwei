# App
APP_NAME=student-service-platform
APP_ENV=development
APP_PORT=8000
APP_BASE_URL=http://localhost:8000

# Frontend
FRONTEND_PORT=3000
FRONTEND_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000/api

# Auth
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=7d

# Database: Kingbase / PostgreSQL-compatible
DB_HOST=localhost
DB_PORT=54321
DB_NAME=student_service_platform
DB_USER=system
DB_PASSWORD=change_me
DB_SCHEMA=public
DB_SSL=false

# File upload / export
UPLOAD_DIR=./storage/uploads
EXPORT_DIR=./storage/exports
MAX_UPLOAD_SIZE_MB=30

# Logging / audit
LOG_LEVEL=info
AUDIT_LOG_ENABLED=true

# Notification
MAIL_ENABLED=false
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASSWORD=
SMS_ENABLED=false
SMS_PROVIDER=
SMS_API_KEY=

# Storage / backup
BACKUP_DIR=./storage/backups

# Notes
# 1. Copy this file to `.env` for local development.
# 2. Replace all placeholder secrets before team use.
# 3. Confirm Kingbase host, port, account, and schema after deployment plan is fixed.
